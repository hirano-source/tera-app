# ── フロント（Vite）用：Supabase 接続（Settings → API からコピー）──
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_KEY=sb_publishable_xxxxxxxx

# ── ローカルMCPサーバー用：あなたのTERAログイン ──
# 「話すだけで仕事が終わる」を自分として動かすため、MCPがこの資格情報で
# Supabaseにサインインする（RLSであなたの権限の範囲だけ操作）。
TERA_EMAIL=you@example.com
TERA_PASSWORD=your-password
